  "keyFeatures": [
    "56+ ready-to-use animation components for Svelte 5",
    "CLI-based installation via shadcn-svelte registry",
    "Built with motion-sv for smooth animations",
    "Fully customizable with Tailwind CSS",
    "Copy-paste component architecture",
    "TypeScript support with full type definitions",
    "Accessible animations with ARIA support",
    "Zero-config installation with automatic dependency management"
  ],
  "publicApiSurface": [
    "text-animate - Text animation with blur, slide, scale effects",
    "animated-gradient-text - Animated gradient background for text",
    "animated-beam - Animated beam effects between elements",
    "blur-fade - Content animation with blur and fade effects",
    "border-beam - Animated border beam effects",
    "animated-grid-pattern - Dynamic background grid pattern",
    "marquee - Smooth scrolling marquee component",
    "typing-animation - Typewriter effect component",
    "morphing-text - Text morphing with blur transitions",
    "orbiting-circles - Circular orbit animations",
    "icon-cloud - 3D tag cloud with rotation",
    "dock - macOS-style dock with magnification",
    "file-tree - Interactive file tree component",
    "hero-video-dialog - Video dialog with animations",
    "number-ticker - Animated number counter",
    "rainbow-button - Button with rainbow gradient",
    "shimmer-button - Button with shimmer effect",
    "ripple-button - Button with ripple effect",
    "terminal - Terminal UI with typing animations",
    "bento-grid - Flexible grid layout system",
    "animated-theme-toggler - Theme toggler with View Transition API",
    "scroll-progress - Page scroll progress indicator",
    "cool-mode - Particle effect on interactions",
    "confetti - Confetti celebration effect"
  ]
